:root{
  --bg:#0E1116; --surface:#171B22; --surface2:#1F242D; --surface3:#272D38;
  --border:#2C333E; --border2:#3A424F;
  --text:#E8EBF0; --text2:#A3ABB8; --text3:#6B7480;
  --accent:#4F8EF7; --accent-dim:#1E3354; --green:#52B788;
  --radius:14px; --radius-sm:9px;
  --font:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{background:var(--bg);color:var(--text);font-family:var(--font);-webkit-font-smoothing:antialiased}
body{line-height:1.5;font-size:15px}
::selection{background:var(--accent-dim)}
.app{max-width:760px;margin:0 auto;min-height:100vh;display:flex;flex-direction:column}

/* HEADER */
.hdr{position:sticky;top:0;z-index:50;background:rgba(14,17,22,.85);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:14px 18px}
.hdr-top{display:flex;align-items:center;justify-content:space-between;gap:12px}
.brand{display:flex;align-items:center;gap:10px}
.brand-logo{width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,var(--accent),#9B7BF0);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:15px;color:#fff;flex-shrink:0}
.brand-txt h1{font-size:15px;font-weight:600;letter-spacing:-.01em}
.brand-txt p{font-size:11px;color:var(--text3)}
.progress-pill{display:flex;align-items:center;gap:6px;background:var(--surface2);border:1px solid var(--border);border-radius:20px;padding:5px 12px;font-size:12px;color:var(--text2);white-space:nowrap}
.progress-pill b{color:var(--green);font-weight:600}
.search-wrap{margin-top:12px;position:relative}
.search-wrap svg{position:absolute;left:13px;top:50%;transform:translateY(-50%);color:var(--text3)}
#search{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:11px 14px 11px 40px;color:var(--text);font-size:14px;font-family:var(--font)}
#search:focus{outline:none;border-color:var(--accent);background:var(--surface3)}
#search::placeholder{color:var(--text3)}

.pbar-wrap{padding:10px 18px 6px}
.pbar{height:5px;background:var(--surface2);border-radius:3px;overflow:hidden}
.pbar-fill{height:100%;background:linear-gradient(90deg,var(--green),var(--accent));border-radius:3px;width:0%;transition:width .4s ease}

.scroll{flex:1;padding:8px 18px 100px}

/* INTRO */
.intro{background:linear-gradient(135deg,var(--surface),var(--surface2));border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:14px}
.intro h2{font-size:15px;font-weight:600;margin-bottom:6px}
.intro p{font-size:13px;color:var(--text2);line-height:1.55}
.intro .hint{margin-top:10px;font-size:12px;color:var(--text3)}

/* COLLAPSIBLE INDEX */
.title-block{margin-bottom:10px}
.title-head{display:flex;align-items:center;gap:11px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;cursor:pointer;transition:border-color .15s;user-select:none}
.title-head:hover{border-color:var(--border2)}
.title-head.open{border-bottom-left-radius:0;border-bottom-right-radius:0;border-color:var(--border2)}
.title-badge{flex-shrink:0;font-size:11px;font-weight:600;color:var(--accent);background:var(--accent-dim);border-radius:6px;padding:4px 9px;letter-spacing:.02em}
.title-info{flex:1;min-width:0}
.title-info .nm{font-size:14px;font-weight:600;color:var(--text);line-height:1.3}
.title-info .meta{font-size:11.5px;color:var(--text3);margin-top:2px}
.chev{flex-shrink:0;color:var(--text3);transition:transform .25s}
.title-head.open .chev{transform:rotate(180deg)}

.title-body{display:none;border:1px solid var(--border2);border-top:none;border-radius:0 0 var(--radius) var(--radius);overflow:hidden}
.title-body.open{display:block}

/* CHAPTER */
.cap-block{border-top:1px solid var(--border)}
.cap-block:first-child{border-top:none}
.cap-head{display:flex;align-items:center;gap:10px;padding:12px 16px;cursor:pointer;background:var(--surface);transition:background .15s;user-select:none}
.cap-head:hover{background:var(--surface2)}
.cap-dot{flex-shrink:0;width:7px;height:7px;border-radius:50%;background:var(--border2)}
.cap-head.has-progress .cap-dot{background:var(--green)}
.cap-name{flex:1;font-size:12.5px;font-weight:500;color:var(--text2);line-height:1.35}
.cap-count{flex-shrink:0;font-size:11px;color:var(--text3);background:var(--surface2);border-radius:10px;padding:2px 8px}
.cap-chev{flex-shrink:0;color:var(--text3);transition:transform .2s;width:15px;height:15px}
.cap-head.open .cap-chev{transform:rotate(180deg)}
.cap-body{display:none;background:var(--bg);padding:6px 10px 10px}
.cap-body.open{display:block}

/* ARTICLE CARD */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;margin-top:8px;transition:border-color .15s}
.card:hover{border-color:var(--border2)}
.card.done{border-color:var(--accent-dim)}
.card-head{padding:13px 14px;cursor:pointer;display:flex;gap:12px;align-items:flex-start}
.art-num{flex-shrink:0;width:40px;height:40px;border-radius:9px;background:var(--surface2);border:1px solid var(--border);display:flex;flex-direction:column;align-items:center;justify-content:center;line-height:1}
.art-num .n{font-size:15px;font-weight:700;color:var(--text)}
.art-num .lbl{font-size:8px;color:var(--text3);margin-top:1px}
.card.done .art-num{background:var(--accent-dim);border-color:var(--accent)}
.card.done .art-num .n{color:var(--accent)}
.head-body{flex:1;min-width:0}
.head-title{font-size:12.5px;font-weight:600;color:var(--text);margin-bottom:3px}
.head-hook{font-size:13px;color:var(--text2);line-height:1.45}
.head-chev{flex-shrink:0;color:var(--text3);transition:transform .2s;margin-top:3px;width:17px;height:17px}
.card.open .head-chev{transform:rotate(180deg)}

.card-body2{display:none;border-top:1px solid var(--border)}
.card.open .card-body2{display:block;animation:fade .25s ease}
@keyframes fade{from{opacity:0}to{opacity:1}}

.view-toggle{display:flex;padding:12px 14px 0;background:var(--surface)}
.vt-btn{flex:1;background:transparent;border:none;border-bottom:2px solid transparent;color:var(--text3);font-size:12.5px;font-weight:500;font-family:var(--font);padding:8px 0;cursor:pointer;transition:all .15s}
.vt-btn.active{color:var(--text);border-bottom-color:var(--accent)}

.view-pane{padding:14px}
.corto-text{font-size:13.5px;color:var(--text);line-height:1.6}
.legal-head{font-size:11px;color:var(--text3);margin-bottom:8px;font-style:italic}
.legal-text{font-size:13px;color:var(--text2);line-height:1.6;white-space:pre-wrap;font-family:var(--font);max-height:320px;overflow-y:auto;padding-right:6px}
.legal-text::-webkit-scrollbar{width:6px}
.legal-text::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}

.card-foot{display:flex;align-items:center;justify-content:flex-end;padding:0 14px 14px}
.done-btn{display:flex;align-items:center;gap:7px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:7px 13px;font-size:12px;color:var(--text2);cursor:pointer;font-family:var(--font);transition:all .15s}
.done-btn:hover{border-color:var(--border2);color:var(--text)}
.done-btn.is-done{background:var(--accent-dim);border-color:var(--accent);color:var(--accent)}

/* QUIZ PLACEHOLDER (formato preparado, sin activar) */
.quiz-cta{margin:10px;border:1px dashed var(--border2);border-radius:var(--radius-sm);padding:14px;display:flex;align-items:center;gap:12px;background:var(--surface);opacity:.65}
.quiz-cta .qi{width:36px;height:36px;border-radius:9px;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.quiz-cta .qt{flex:1}
.quiz-cta .qt .qh{font-size:12.5px;font-weight:600;color:var(--text2)}
.quiz-cta .qt .qs{font-size:11px;color:var(--text3);margin-top:2px}
.quiz-cta .qbadge{font-size:10px;color:var(--text3);border:1px solid var(--border);border-radius:20px;padding:3px 9px}

/* SEARCH RESULTS */
.results-label{font-size:11px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--text3);margin:4px 2px 10px}
.empty{text-align:center;padding:60px 20px;color:var(--text3)}
.empty svg{margin-bottom:12px;opacity:.5}

.footer{padding:20px 18px 30px;text-align:center;font-size:11px;color:var(--text3);line-height:1.6}
